root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{swift,h,m,c,py}]
indent_style = space
indent_size = 4

[*.{sh,yml,yaml,json}]
indent_style = space
indent_size = 2

[*.pbxproj]
indent_style = tab
indent_size = 4
